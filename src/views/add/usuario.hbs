<section class="mt-5">
    <h3 class="text-center my-4">Agregar Nuevo Usuario</h3>

    {{#if success_msg}}
        <div class="alert-overlay" id="auto-dismiss-alert">
            <div class="alert alert-success custom-alert d-flex align-items-center shadow-lg" role="alert">
                <i class="fas fa-check-circle fs-4 me-3"></i>
                <div>
                    <strong>¡Éxito!</strong><br>
                    {{success_msg}}
                </div>
            </div>
        </div>
    {{/if}}
    {{#if error_msg}}
        <div class="alert-overlay" id="auto-dismiss-alert">
            <div class="alert alert-danger custom-alert d-flex align-items-center shadow-lg" role="alert">
                <i class="fas fa-exclamation-triangle fs-4 me-3"></i>
                <div>
                    <strong>Atención</strong><br>
                    {{error_msg}}
                </div>
            </div>
        </div>
    {{/if}}

    <form id="formAgregarUsuario" action="/usuario/guardar" method="POST" class="container form-General p-4 border rounded shadow-sm">
        <p><font color="red">*</font> Son campos obligatorios</p>

        <div class="row">
            <div class="col-md-6">
                <label>Nombre de Usuario<font color="red">*</font></label>
                <input type="text" name="nombre_usuario" class="form-control" required>
            </div>
            <div class="col-md-6">
                <label>Correo Electrónico</label>
                <input type="email" name="correo_electronico" id="correo_electronico" class="form-control">
                <div class="invalid-feedback">
                    Por favor, ingrese un correo electrónico válido (ej. usuario@dominio.com).
                </div>
            </div>
        </div>

        <div class="row mt-3">
            <div class="col-md-3">
                <label>Primer Nombre<font color="red">*</font></label>
                <input type="text" name="primer_nombre" class="form-control" required>
            </div>
            <div class="col-md-3">
                <label>Segundo Nombre</label>
                <input type="text" name="segundo_nombre" class="form-control">
            </div>
            <div class="col-md-3">
                <label>Primer Apellido<font color="red">*</font></label>
                <input type="text" name="primer_apellido" class="form-control" required>
            </div>
            <div class="col-md-3">
                <label>Segundo Apellido</label>
                <input type="text" name="segundo_apellido" class="form-control">
            </div>
        </div>

        <div class="row mt-3">
            <div class="col-md-6">
                <label>Contraseña<font color="red">*</font></label>
                <div class="input-group">
                    <input type="password" name="contrasenia" id="contrasenia" class="form-control" required>
                    <button class="btn btn-outline-secondary toggle-password" type="button" data-target="contrasenia">
                        <i class="fas fa-eye"></i>
                    </button>
                    <div class="invalid-feedback">
                        La contraseña debe tener mínimo 8 caracteres, una mayúscula, una minúscula, un número y un carácter especial.
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <label>Confirmar Contraseña<font color="red">*</font></label>
                <div class="input-group">
                    <input type="password" name="confirmar_contrasenia" id="confirmar_contrasenia" class="form-control" required>
                    <button class="btn btn-outline-secondary toggle-password" type="button" data-target="confirmar_contrasenia">
                        <i class="fas fa-eye"></i>
                    </button>
                    <div class="invalid-feedback">
                        Las contraseñas no coinciden.
                    </div>
                </div>
            </div>
        </div>

        <div class="row mt-3">
            <div class="col-md-6">
                <label>Rol<font color="red">*</font></label>
                <select name="id_rol" class="form-select" required>
                    <option value="">Seleccione un rol</option>
                    {{#each roles}}
                        <option value="{{this.id_rol}}">{{this.rol}}</option>
                    {{/each}}
                </select>
            </div>
        </div>

        <div class="text-center mt-4">
            <button type="submit" class="btn-guardar me-2">Guardar Usuario</button>
            <a href="/usuario/table" class="btn btn-secondary">Cancelar</a>
        </div>
    </form>
</section>